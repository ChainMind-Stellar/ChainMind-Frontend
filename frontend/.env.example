# FRONTEND ENVIRONMENT VARIABLES
# ------------------------------

# URL of your backend API (FastAPI)
# Local development: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Contract Addresses (If needed for frontend interactions via wagmi/ethers)
NEXT_PUBLIC_REGISTRY_ADDRESS=0x_deployed_main_registry_address
NEXT_PUBLIC_IDENTITY_REGISTRY=0x_deployed_identity_registry_address
NEXT_PUBLIC_REPUTATION_REGISTRY=0x_deployed_reputation_registry_address
NEXT_PUBLIC_PAYMENT_GATEWAY_ADDRESS=0x_deployed_payment_gateway_address

# Default cUSD address on Alfajores
NEXT_PUBLIC_CUSD_TOKEN_ADDRESS=

# WalletConnect Project ID (If using RainbowKit/AppKit)
# Get one at: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
